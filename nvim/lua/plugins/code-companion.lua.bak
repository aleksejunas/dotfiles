-- ~/.config/nvim/lua/plugins/code-companion.lua
return {
  "olimorris/codecompanion.nvim",
  dependencies = {
    "nvim-lua/plenary.nvim",
    "MunifTanjim/nui.nvim",
    { "nvim-tree/nvim-web-devicons", optional = true },
    { "nvim-telescope/telescope.nvim", optional = true },
    { "folke/which-key.nvim", optional = true },
  },
  cmd = { "CodeCompanion", "CodeCompanionChat" },
  config = function()
    -- Helper: list tracked files minus YAML/lock/build dirs
    local function git_files_filtered()
      local cmd = [[bash -lc "git ls-files \
        | grep -v '\\.ya\\?ml$' \
        | grep -v 'lock$' \
        | grep -v '^dist/' \
        | grep -v '^build/' \
        | grep -v '^out/' \
        | grep -v '^coverage/' \
        | grep -v '^node_modules/'"]]
      local h = io.popen(cmd)
      if not h then
        return {}
      end
      local out = h:read("*a")
      h:close()
      local t = {}
      for f in out:gmatch("[^\r\n]+") do
        t[#t + 1] = f
      end
      return t
    end

    require("codecompanion").setup({
      -- Pick your default adapters per strategy
      strategies = {
        chat = {
          adapter = "copilot", -- change if you use another
          -- VALID keymaps schema (each action has modes/opts)
          keymaps = {
            send = { modes = { n = "<C-s>", i = "<C-s>" }, opts = {} },
            close = { modes = { n = "q", i = "<C-c>" }, opts = {} },
            -- add more actions if you want: regenerate, stop, etc.
          },
        },
        inline = {
          adapter = "openai",
        },
      },

      -- Optional: configure adapters (api keys, models, etc.)
      adapters = {
        -- Example: tweak OpenAI default model if you care
        openai = function()
          return require("codecompanion.adapters").extend("openai", {
            schema = { model = { default = "gpt-4.1" } },
            env = { api_key = "OPENAI_API_KEY" }, -- or keep in env var
          })
        end,
      },

      -- Memory: persistent context that autoloads in new chats
      memory = {
        opts = {
          chat = {
            enabled = true,
            default_memory = { "project_all" },
            -- default_params = "pin", -- optional: pin linked buffers
          },
        },
        project_all = {
          description = "All tracked project files minus YAML/lock/build",
          files = git_files_filtered(),
          -- parser = "none" -- set "claude" if you use markdown memory files
        },
      },

      -- UI niceties
      display = {
        chat = { window = { border = "rounded" } },
        diff = { enabled = true },
      },
    })
  end,
}
